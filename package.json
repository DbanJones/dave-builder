{
  "name": "dave-builder",
  "version": "0.1.0-demo",
  "private": true,
  "type": "module",
  "description": "Dave-Builder (Demo). Desktop app that lets absolute novices build production web apps by chatting with Dave. Demo build locks down on the configured expiry date — see lib/demo/config.ts.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "sidecar:install": "corepack pnpm --dir sidecar install",
    "sidecar:build": "corepack pnpm --dir sidecar build",
    "sidecar:package": "node scripts/package-sidecar.mjs",
    "claude-cli:package": "node scripts/package-claude-cli.mjs",
    "predev": "corepack pnpm sidecar:build",
    "prebuild": "corepack pnpm sidecar:build && corepack pnpm sidecar:package && corepack pnpm claude-cli:package",
    "typecheck": "tsc --noEmit && corepack pnpm --dir sidecar typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "pretest:integration": "corepack pnpm sidecar:build",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "e2e": "playwright test",
    "verify": "corepack pnpm typecheck && corepack pnpm lint && corepack pnpm test:unit && corepack pnpm test:integration"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@hookform/resolvers": "5.2.2",
    "@tauri-apps/plugin-dialog": "2.7.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.11.0",
    "neverthrow": "8.2.0",
    "next": "15.5.15",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.74.0",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "xlsx": "0.18.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@playwright/test": "1.59.1",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/cli": "2.10.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "2.1.9",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-plugin-neverthrow": "1.1.4",
    "jsdom": "25.0.1",
    "postcss": "8.4.31",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vitest": "2.1.9"
  }
}
